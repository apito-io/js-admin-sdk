{
  "name": "@apito-io/js-admin-sdk",
  "version": "2.1.0",
  "description": "Admin JavaScript SDK for Apito GraphQL API (mirrors go-internal-sdk)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "prepare": "tsup",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "keywords": [
    "apito",
    "sdk",
    "graphql",
    "api",
    "javascript",
    "typescript",
    "headless-cms",
    "backend"
  ],
  "author": "Apito Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apito-io/js-admin-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/apito-io/js-admin-sdk/issues"
  },
  "homepage": "https://docs.apito.io",
  "dependencies": {
    "axios": "^1.14.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "size-limit": "^12.0.1",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "50 KB"
    },
    {
      "path": "dist/index.mjs",
      "limit": "50 KB"
    }
  ],
  "publishConfig": {
    "access": "public"
  }
}
