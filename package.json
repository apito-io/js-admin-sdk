{
  "name": "@apito-io/js-admin-sdk",
  "version": "1.0.2",
  "description": "Admin JavaScript SDK for Apito GraphQL API — core, react headless, ui contracts",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "apito-codegen": "./bin/apito-codegen.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js",
      "default": "./dist/react.mjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.mjs",
      "require": "./dist/ui.js",
      "default": "./dist/ui.mjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "scripts"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup && node scripts/postbuild-dts.mjs",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "gen:operations": "tsx scripts/gen-operations.ts",
    "gen:types": "graphql-codegen --config codegen.ts",
    "gen": "npm run gen:operations && npm run gen:types",
    "gen:project-hooks": "tsx scripts/gen-project-hooks.ts"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "graphql": ">=16.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "graphql": { "optional": true }
  },
  "keywords": ["apito", "sdk", "graphql", "admin", "typescript"],
  "author": "Apito Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.14.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-generic-sdk": "^4.0.3",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@graphql-codegen/typescript-react-query": "^6.1.1",
    "@tanstack/react-query": "^5.90.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "react": "^19.1.0",
    "size-limit": "^12.0.1",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "~5.8.3",
    "inflection": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
