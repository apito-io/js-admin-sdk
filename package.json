{
  "name": "@apito-io/js-admin-sdk",
  "version": "3.7.0",
  "description": "Admin JavaScript SDK for Apito GraphQL API (mirrors go-internal-sdk)",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workerd": "./dist/index.mjs",
      "worker": "./dist/index.mjs",
      "browser": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup && cp dist/index.d.mts dist/index.d.ts",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "prepare": "tsup",
    "size": "size-limit",
    "analyze": "size-limit --why",
    "gen:operations": "tsx scripts/gen-operations.ts",
    "gen:types": "graphql-codegen --config codegen.ts",
    "gen": "npm run gen:operations && npm run gen:types",
    "gen:project-hooks": "tsx scripts/gen-project-hooks.ts"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "graphql": ">=16.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "graphql": {
      "optional": true
    }
  },
  "keywords": [
    "apito",
    "sdk",
    "graphql",
    "api",
    "javascript",
    "typescript",
    "headless-cms",
    "backend"
  ],
  "author": "Apito Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apito-io/js-admin-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/apito-io/js-admin-sdk/issues"
  },
  "homepage": "https://docs.apito.io",
  "dependencies": {
    "axios": "^1.14.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-generic-sdk": "^4.0.3",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@graphql-codegen/typescript-react-query": "^6.1.1",
    "@tanstack/react-query": "^5.90.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "size-limit": "^12.0.1",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "inflection": "^3.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "50 KB"
    },
    {
      "path": "dist/index.mjs",
      "limit": "120 KB"
    }
  ],
  "publishConfig": {
    "access": "public"
  }
}
